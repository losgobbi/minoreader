CREATE TABLE Article (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    feedId INTEGER NOT NULL,
    guid TEXT NOT NULL,
    title TEXT NOT NULL,
    link TEXT,
    author TEXT,
    publishedAt INTEGER,
    excerpt TEXT,
    contentHtml TEXT,
    isRead INTEGER NOT NULL DEFAULT 0,
    isFavorite INTEGER NOT NULL DEFAULT 0,
    fetchedAt INTEGER NOT NULL,
    UNIQUE(feedId, guid),
    FOREIGN KEY(feedId) REFERENCES Feed(id) ON DELETE CASCADE
);

CREATE INDEX article_feed_idx ON Article(feedId);
CREATE INDEX article_unread_idx ON Article(isRead);
CREATE INDEX article_fav_idx ON Article(isFavorite);

insertArticle:
INSERT OR IGNORE INTO Article(feedId, guid, title, link, author, publishedAt, excerpt, contentHtml, fetchedAt)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

setContentHtml:
UPDATE Article SET contentHtml = ? WHERE id = ?;

selectUnread:
SELECT Article.*, Feed.title AS feedTitle, Feed.category AS category
FROM Article JOIN Feed ON Article.feedId = Feed.id
WHERE Article.isRead = 0
ORDER BY Article.publishedAt DESC, Article.fetchedAt DESC;

selectUnreadByCategory:
SELECT Article.*, Feed.title AS feedTitle, Feed.category AS category
FROM Article JOIN Feed ON Article.feedId = Feed.id
WHERE Article.isRead = 0 AND Feed.category = ?
ORDER BY Article.publishedAt DESC, Article.fetchedAt DESC;

selectFavorites:
SELECT Article.*, Feed.title AS feedTitle, Feed.category AS category
FROM Article JOIN Feed ON Article.feedId = Feed.id
WHERE Article.isFavorite = 1
ORDER BY Article.publishedAt DESC, Article.fetchedAt DESC;

selectArticleById:
SELECT Article.*, Feed.title AS feedTitle, Feed.category AS category
FROM Article JOIN Feed ON Article.feedId = Feed.id
WHERE Article.id = ?;

selectRead:
SELECT Article.*, Feed.title AS feedTitle, Feed.category AS category
FROM Article JOIN Feed ON Article.feedId = Feed.id
WHERE Article.isRead = 1
ORDER BY Article.fetchedAt DESC, Article.publishedAt DESC
LIMIT 300;

searchArticles:
SELECT Article.*, Feed.title AS feedTitle, Feed.category AS category
FROM Article JOIN Feed ON Article.feedId = Feed.id
WHERE Article.title LIKE '%' || :query || '%' OR Article.excerpt LIKE '%' || :query || '%'
ORDER BY Article.publishedAt DESC, Article.fetchedAt DESC
LIMIT 200;

setRead:
UPDATE Article SET isRead = ? WHERE id = ?;

setFavorite:
UPDATE Article SET isFavorite = ? WHERE id = ?;

countUnread:
SELECT count(*) FROM Article WHERE isRead = 0;
